{
  "appId": "com.fuevolt.app",
  "appName": "FueVolt",
  "webDir": "dist",
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0D2B5E",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "backgroundColor": "#0D2B5E",
      "style": "DARK"
    }
  },
  "android": {
    "allowMixedContent": true
  }
}
